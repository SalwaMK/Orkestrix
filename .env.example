# Database mode: 'sqlite' (local) or 'neon' (hosted)
VITE_DB_MODE=sqlite

# Neon connection string — only needed when VITE_DB_MODE=neon
VITE_DATABASE_URL=

# App name
VITE_APP_NAME=Orkestrix

# Encryption secret for API keys stored in DB
# Generate a random string: openssl rand -base64 32
VITE_ENCRYPTION_SECRET=

# Anthropic API key — used for Gmail receipt parsing
VITE_ANTHROPIC_API_KEY=

# Google OAuth — for Gmail scanning
# Set up at console.cloud.google.com
VITE_GMAIL_CLIENT_ID=
VITE_GMAIL_CLIENT_SECRET=
VITE_GMAIL_REDIRECT_URI=http://localhost:3001/auth/gmail/callback